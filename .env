function verificarApiKey(req, res, next) {
  const key = req.headers["x-api-key"];

  if (key !== process.env.API_KEY) {
    return res.status(401).json({ ok: false, error: "API Key inválida" });
  }

  next();
}

app.post("/api/titulares", verificarApiKey, async (req,res)=>{
  const { nome, email, telefone } = req.body;

  if (!nome || !email || !telefone) {
    return res.status(400).json({ ok: false, error: "Campos obrigatórios: nome, email, telefone" });
  }

  try {
    const r = await pool.query(`
      INSERT INTO titulares (nome, email, telefone)
      VALUES ($1, $2, $3)
      RETURNING id
    `, [nome, email, telefone]);

    res.json({ ok: true, titular_id: r.rows[0].id });
  } catch (err) {
    console.error(err);
    res.status(500).json({ ok: false, error: "Erro ao criar titular" });
  }
})